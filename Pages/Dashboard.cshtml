@page
@model DashboardModel
@using Microsoft.AspNetCore.Html
@{
    ViewData["Title"] = "Dashboard";

    var eqpMap = Model.EquipmentByName;

    // タイプ別装置名リスト (画像のレイアウト順)
    var eqpHiTempPyro      = new[] { "DVETD05","DVETD30","DVETD31","DVETD41","DVETD42","DVETD43","DVETD44","DVETD45","DVETD60","DVETD65","DVETD70","DVETD85" };
    var eqpVdfBaox         = new[] { "DVETD79" };
    var eqpOnoOx           = new[] { "DVETD81" };
    var eqpHiTempDryPre    = new[] { "DVETD48","DVETD55","DVETD56","DVETD57","DVETD71","DVETD73" };
    var eqpHiTempDryPost   = new[] { "DVETD53","DVETD54","DVETD62","DVETD67","DVETD75","DVETD76","DVETD77","DVETD82" };
    var eqpShiTempPyro     = new[] { "DVETD49","DVETD87","DVETD88","DVETV57" };
    var eqpShiTempDryVhvic = new[] { "DVETD04","DVETD83" };
    var eqpPyroGate        = new[] { "DVETD27","DVETD28","DVETD66","DVETD80","DVETD84" };
    var eqpFramPyroGate    = new[] { "DVETD59" };
    var eqpVcfDasiOn       = new[] { "DVETC07","DVETC27","DVETC33","DVETC35","DVETC36","DVETC38","DVETC51","DVETC52","DVETC68","DVETC74" };
    var eqpIgbtDasi        = new[] { "DVETC77" };
    var eqpVcfPoly         = new[] { "DVETC37","DVETC53","DVETC71" };
    var eqpOnoSin          = new[] { "DVETC54","DVETC61","DVETC70" };
    var eqpIsoSin          = new[] { "DVETC55","DVETC56" };
    var eqpVcfHto          = new[] { "DVETC57","DVETC59" };
    var eqpVcfHtoOno       = new[] { "DVETC63" };
    var eqpGSio            = new[] { "DVETC25","DVETC28","DVETC40","DVETC60" };
    var eqpVcfTeos         = new[] { "DVETC26","DVETC31","DVETC32","DVETC34","DVETC39" };

    // 装置カードレンダリング関数
    HtmlString Card(string n)
    {
        eqpMap.TryGetValue(n, out var e);
        var ip = e?.InProcess.Count ?? 0;
        var wt = e?.Waiting.Count ?? 0;
        var r1 = e?.Reserved1.Count ?? 0;
        var r2 = e?.Reserved2.Count ?? 0;
        var r3 = e?.Reserved3.Count ?? 0;
        var et = System.Net.WebUtility.HtmlEncode(e?.InProcess.FirstOrDefault()?.EndTime ?? "");
        var sc = System.Net.WebUtility.HtmlEncode(e?.Schedule ?? "");
        return new HtmlString(
            "<div class=\"eqp-card\">" +
            "<div class=\"eqp-top-row\">" +
            "<div class=\"eqp-cell-a\" id=\"cell-a-" + n + "\" onclick=\"showCarrierPopup('" + n + "','inProcess')\">" + (ip > 0 ? ip.ToString() : "") + "</div>" +
            "<div class=\"eqp-cell-b\" id=\"cell-b-" + n + "\" onclick=\"showCarrierPopup('" + n + "','waiting')\">" + (wt > 0 ? wt.ToString() : "") + "</div>" +
            "</div>" +
            "<div class=\"eqp-endtime-row\" id=\"cell-f-" + n + "\">" + et + "</div>" +
            "<div class=\"eqp-reserve-row\">" +
            "<div class=\"eqp-cell-g\" id=\"cell-g-" + n + "\">" + sc + "</div>" +
            "<div class=\"eqp-cell-c\" id=\"cell-c-" + n + "\" onclick=\"showCarrierPopup('" + n + "','reserved1')\">" + (r1 > 0 ? r1.ToString() : "") + "</div>" +
            "<div class=\"eqp-cell-d\" id=\"cell-d-" + n + "\" onclick=\"showCarrierPopup('" + n + "','reserved2')\">" + (r2 > 0 ? r2.ToString() : "") + "</div>" +
            "<div class=\"eqp-cell-e\" id=\"cell-e-" + n + "\" onclick=\"showCarrierPopup('" + n + "','reserved3')\">" + (r3 > 0 ? r3.ToString() : "") + "</div>" +
            "</div>" +
            "<div class=\"eqp-name-row\" id=\"cell-h-" + n + "\" onclick=\"location.href='/WipLotList?EqpName=" + n + "'\">" + n + "</div>" +
            "</div>"
        );
    }
}

<form id="csrfForm" style="display:none;">@Html.AntiForgeryToken()</form>

<div class="dash-wrapper">
    <!-- ヘッダー -->
    <div class="dash-header">
        <span class="dash-title">Dashboard</span>
        <span class="dash-sub">装置状態一覧</span>
    </div>

    <!-- メインエリア (グリッド + フィルターパネル) -->
    <div class="dash-body">

        <!-- 14列固定グリッド -->
        <div class="type-grid">

            <!-- ===== Row 1: Hi_temp_Pyro | VDF_BAOX | ONO_OX ===== -->

            <div class="type-group" id="grp-HiTempPyro" data-line="A" style="grid-column:1/13;grid-row:1">
                <div class="type-hdr"><span>Hi temp Pyro</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpHiTempPyro) { @Card(n) }</div>
            </div>

            <div class="type-group" id="grp-VdfBaox" data-line="A" style="grid-column:13/14;grid-row:1">
                <div class="type-hdr"><span>VDF_BAOX</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpVdfBaox) { @Card(n) }</div>
            </div>

            <div class="type-group" id="grp-OnoOx" data-line="A" style="grid-column:14/15;grid-row:1">
                <div class="type-hdr"><span>ONO_OX</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpOnoOx) { @Card(n) }</div>
            </div>

            <!-- ===== Row 2: Hi_Temp_Dry_Pre | Hi_temp_Dry_Post ===== -->

            <div class="type-group" id="grp-HiTempDryPre" data-line="A" style="grid-column:1/7;grid-row:2">
                <div class="type-hdr"><span>Hi Temp Dry Pre</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpHiTempDryPre) { @Card(n) }</div>
            </div>

            <div class="type-group" id="grp-HiTempDryPost" data-line="A" style="grid-column:7/15;grid-row:2">
                <div class="type-hdr"><span>Hi_temp Dry Post</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpHiTempDryPost) { @Card(n) }</div>
            </div>

            <!-- ===== Row 3: S_hi_temp_Pyro | S_hi_temp_Dry_VHVIC | Pyro_Gate | FRAM_Pyro_Gate ===== -->

            <div class="type-group" id="grp-ShiTempPyro" data-line="A" style="grid-column:1/5;grid-row:3">
                <div class="type-hdr"><span>S hi_temp Pyro</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpShiTempPyro) { @Card(n) }</div>
            </div>

            <div class="type-group" id="grp-ShiTempDryVhvic" data-line="A" style="grid-column:5/7;grid-row:3">
                <div class="type-hdr"><span>S hi_temp Dry VHVIC</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpShiTempDryVhvic) { @Card(n) }</div>
            </div>

            <div class="type-group" id="grp-PyroGate" data-line="A" style="grid-column:7/12;grid-row:3">
                <div class="type-hdr"><span>Pyro Gate</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpPyroGate) { @Card(n) }</div>
            </div>

            <div class="type-group" id="grp-FramPyroGate" data-line="A" style="grid-column:12/13;grid-row:3">
                <div class="type-hdr"><span>FRAM Pyro Gate</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpFramPyroGate) { @Card(n) }</div>
            </div>

            <!-- ===== Row 4: VCF_DASI_ON | IGBT_DASI ===== -->

            <div class="type-group" id="grp-VcfDasiOn" data-line="B" style="grid-column:1/11;grid-row:4">
                <div class="type-hdr"><span>VCF_DASI_ON</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpVcfDasiOn) { @Card(n) }</div>
            </div>

            <div class="type-group" id="grp-IgbtDasi" data-line="B" style="grid-column:11/12;grid-row:4">
                <div class="type-hdr"><span>IGBT/DASI</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpIgbtDasi) { @Card(n) }</div>
            </div>

            <!-- ===== Row 5: VCF_POLY | ONO_SIN | ISO_SIN | VCF_HTO | VCF_HTO_ONO ===== -->

            <div class="type-group" id="grp-VcfPoly" data-line="B" style="grid-column:1/4;grid-row:5">
                <div class="type-hdr"><span>VCF_POLY</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpVcfPoly) { @Card(n) }</div>
            </div>

            <div class="type-group" id="grp-OnoSin" data-line="B" style="grid-column:4/7;grid-row:5">
                <div class="type-hdr"><span>ONO_SIN</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpOnoSin) { @Card(n) }</div>
            </div>

            <div class="type-group" id="grp-IsoSin" data-line="B" style="grid-column:7/9;grid-row:5">
                <div class="type-hdr"><span>ISO_SIN</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpIsoSin) { @Card(n) }</div>
            </div>

            <div class="type-group" id="grp-VcfHto" data-line="B" style="grid-column:9/11;grid-row:5">
                <div class="type-hdr"><span>VCF_HTO</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpVcfHto) { @Card(n) }</div>
            </div>

            <div class="type-group" id="grp-VcfHtoOno" data-line="B" style="grid-column:11/12;grid-row:5">
                <div class="type-hdr"><span>VCF_HTO_ONO</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpVcfHtoOno) { @Card(n) }</div>
            </div>

            <!-- ===== Row 6: G_SIO | VCF_TEOS ===== -->

            <div class="type-group" id="grp-GSio" data-line="B" style="grid-column:1/5;grid-row:6">
                <div class="type-hdr"><span>G_SIO</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpGSio) { @Card(n) }</div>
            </div>

            <div class="type-group" id="grp-VcfTeos" data-line="B" style="grid-column:5/10;grid-row:6">
                <div class="type-hdr"><span>VCF_TEOS</span><label class="yuu-label"><input type="checkbox" class="yuu-chk" onchange="toggleYuu(this)"> 優</label></div>
                <div class="type-eqps">@foreach (var n in eqpVcfTeos) { @Card(n) }</div>
            </div>

        </div><!-- /type-grid -->

        <!-- フィルターパネル -->
        <div class="filter-panel">
            <div class="fp-title">フィルター</div>
            <label class="fp-item"><input type="checkbox" id="filterA" checked onchange="applyLineFilter()"> A-LINE</label>
            <label class="fp-item"><input type="checkbox" id="filterB" checked onchange="applyLineFilter()"> B-LINE</label>
        </div>

    </div><!-- /dash-body -->

    <!-- キャリア詳細ポップアップ -->
    <div class="cp-overlay" id="cp-overlay" onclick="closeCarrierPopup()"></div>
    <div class="cp-modal" id="cp-modal">
        <div class="cp-header">
            <span class="cp-title" id="cp-title"></span>
            <button class="cp-close" onclick="closeCarrierPopup()">×</button>
        </div>
        <div class="cp-body">
            <table class="cp-table" id="cp-table">
                <thead>
                    <tr>
                        <th>Carrier</th>
                        <th>Lot</th>
                        <th style="text-align:right;">Qty</th>
                        <th>PPID</th>
                        <th>Next</th>
                        <th>Loc</th>
                        <th>End</th>
                    </tr>
                </thead>
                <tbody id="cp-tbody"></tbody>
            </table>
            <div class="cp-empty" id="cp-empty" style="display:none;">データなし</div>
        </div>
    </div>

</div>

<style>
    * { box-sizing: border-box; }

    body {
        background: #fff;
        margin: 0;
        padding: 0;
        overflow: hidden;
    }

    .dash-wrapper {
        display: flex;
        flex-direction: column;
        height: 100vh;
        padding: 4px;
        gap: 4px;
    }

    /* ヘッダー */
    .dash-header {
        background: #1565c0;
        color: #fff;
        padding: 3px 10px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }
    .dash-title { font-size: 1rem; font-weight: 700; }
    .dash-sub   { font-size: 0.75rem; opacity: 0.85; }

    /* メインエリア */
    .dash-body {
        flex: 1;
        min-height: 0;
        overflow: hidden;
    }

    /* 14列グリッド */
    .type-grid {
        display: grid;
        grid-template-columns: repeat(14, 1fr);
        grid-template-rows: repeat(6, auto);
        gap: 3px;
        width: 100%;
        align-content: start;
    }

    /* タイプグループ (ボーダー囲み) */
    .type-group {
        border: 2px solid #444;
        background: #fff;
        min-width: 0;
        overflow: hidden;
    }
    .type-group.yuu-active {
        border: 3px solid #e00000 !important;
    }
    .type-group.line-hidden {
        visibility: hidden;
    }

    /* タイプヘッダー */
    .type-hdr {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1px 3px;
        font-size: 0.7rem;
        font-weight: 700;
        background: #ccc;
        border-bottom: 1px solid #555;
        white-space: nowrap;
        overflow: hidden;
        line-height: 1.3;
    }
    .type-hdr > span {
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* 優チェックボックスラベル */
    .yuu-label {
        display: flex;
        align-items: center;
        gap: 1px;
        font-size: 0.7rem;
        font-weight: 700;
        cursor: pointer;
        flex-shrink: 0;
        margin-left: 2px;
        color: #333;
    }
    .yuu-chk {
        width: 11px;
        height: 11px;
        cursor: pointer;
        accent-color: #e00000;
    }

    /* 装置カード列 */
    .type-eqps {
        display: flex;
        gap: 4px;
        padding: 3px;
        flex-wrap: nowrap;
    }

    /* 装置カード */
    .eqp-card {
        flex: 1;
        min-width: 0;
        border: 1px solid #444;
        background: #fff;
    }

    .eqp-top-row {
        display: flex;
        border-bottom: 1px solid #444;
    }

    .eqp-cell-a {
        flex: 1;
        background: #4CAF50;
        text-align: center;
        font-size: 1rem;
        font-weight: 700;
        height: 32px;
        line-height: 32px;
        border-right: 1px solid #444;
        color: #000;
        cursor: pointer;
    }
    .eqp-cell-b {
        flex: 1;
        background: #4CAF50;
        text-align: center;
        font-size: 1rem;
        font-weight: 700;
        height: 32px;
        line-height: 32px;
        color: #000;
        cursor: pointer;
    }

    .eqp-endtime-row {
        text-align: center;
        font-size: 0.7rem;
        border-bottom: 1px solid #444;
        height: 16px;
        line-height: 16px;
        color: #333;
        overflow: hidden;
    }

    .eqp-reserve-row {
        display: flex;
        border-bottom: 1px solid #444;
    }
    .eqp-cell-g {
        flex: 1;
        background: #fff;
        border-right: 1px solid #444;
        height: 24px;
        line-height: 24px;
        text-align: center;
        font-size: 0.75rem;
        font-weight: 700;
        color: #fff;
        overflow: hidden;
    }
    .eqp-cell-g:not(:empty) {
        background: #e67e22;
    }
    .eqp-cell-c,
    .eqp-cell-d,
    .eqp-cell-e {
        flex: 1;
        background: #FFC107;
        text-align: center;
        font-weight: 700;
        font-size: 0.85rem;
        color: #000;
        border-right: 1px solid #444;
        height: 24px;
        line-height: 24px;
        cursor: pointer;
    }
    .eqp-cell-e { border-right: none; }

    .eqp-name-row {
        text-align: center;
        padding: 0 1px;
        font-weight: 700;
        font-size: 0.65rem;
        color: #000;
        height: 16px;
        line-height: 16px;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
        cursor: pointer;
    }
    .eqp-name-row:hover {
        background: #ddd;
        text-decoration: underline;
    }

    /* キャリア詳細ポップアップ */
    .cp-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: rgba(0,0,0,0.45);
        z-index: 1000;
    }
    .cp-modal {
        display: none;
        position: fixed;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        background: #fff;
        border: 2px solid #444;
        border-radius: 4px;
        z-index: 1001;
        min-width: 520px;
        max-width: 90vw;
        max-height: 80vh;
        overflow: hidden;
        display: none;
        flex-direction: column;
    }
    .cp-header {
        background: #1565c0;
        color: #fff;
        padding: 5px 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }
    .cp-title { font-weight: 700; font-size: 0.9rem; }
    .cp-close {
        background: none; border: none; color: #fff;
        font-size: 1.2rem; cursor: pointer; padding: 0 4px; line-height: 1;
    }
    .cp-body {
        overflow-y: auto;
        padding: 8px;
    }
    .cp-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.78rem;
    }
    .cp-table th {
        background: #e0e0e0;
        border: 1px solid #aaa;
        padding: 3px 6px;
        white-space: nowrap;
    }
    .cp-table td {
        border: 1px solid #ddd;
        padding: 2px 6px;
        white-space: nowrap;
    }
    .cp-table tr:nth-child(even) td { background: #f9f9f9; }
    .cp-empty {
        text-align: center;
        color: #999;
        padding: 20px;
        font-size: 0.8rem;
    }

    /* フィルターパネル */
    .filter-panel {
        position: fixed;
        bottom: 20px;
        right: 20px;
        width: 90px;
        border: 2px solid #666;
        background: #f5f5f5;
        padding: 8px;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0,0,0,0.25);
        border-radius: 4px;
    }

    /* グリッド下部がフィルターに隠れないよう余白 */
    .type-grid {
        padding-bottom: 90px;
    }
    .fp-title {
        font-weight: 700;
        margin-bottom: 6px;
        border-bottom: 1px solid #aaa;
        padding-bottom: 2px;
        font-size: 0.75rem;
    }
    .fp-item {
        display: flex;
        align-items: center;
        gap: 4px;
        cursor: pointer;
        margin-bottom: 4px;
        font-size: 0.75rem;
    }
</style>

@section Scripts {
<script>
    // DB から読み込んだ優フラグ (grp-XXX の XXX 部分をキーとして使用)
    const yuuTypes = new Set(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.YuuTypes)));

    // 優チェックボックス: ONで赤ボーダー表示 + DBへ保存
    function toggleYuu(checkbox) {
        const grp = checkbox.closest('.type-group');
        if (!grp) return;
        grp.classList.toggle('yuu-active', checkbox.checked);
        const typeName = grp.id.replace('grp-', '');
        saveYuu(typeName, checkbox.checked ? 1 : 0);
    }

    async function saveYuu(typeName, yuu) {
        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const formData = new FormData();
            formData.append('typeName', typeName);
            formData.append('yuu', yuu);
            formData.append('__RequestVerificationToken', token);
            await fetch('@Url.Page("/Dashboard", new { handler = "ToggleYuu" })', {
                method: 'POST',
                body: formData
            });
        } catch (e) {
            console.error('優保存エラー:', e);
        }
    }

    // ページロード時: DBの優フラグを反映
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.yuu-chk').forEach(chk => {
            const grp = chk.closest('.type-group');
            if (!grp) return;
            const typeName = grp.id.replace('grp-', '');
            if (yuuTypes.has(typeName)) {
                chk.checked = true;
                grp.classList.add('yuu-active');
            }
        });
        startAutoRefresh();
    });

    // LINEフィルター: 非選択LINEのグループを非表示
    function applyLineFilter() {
        const showA = document.getElementById('filterA').checked;
        const showB = document.getElementById('filterB').checked;
        document.querySelectorAll('.type-group').forEach(grp => {
            const line = grp.getAttribute('data-line');
            const hidden = (line === 'A' && !showA) || (line === 'B' && !showB);
            grp.classList.toggle('line-hidden', hidden);
        });
    }

    // 装置データキャッシュ (eqpName → EquipmentProgressViewModel)
    let eqpData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.EquipmentByName,
        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }
    ));

    // キャリア詳細ポップアップ
    const statusLabels = {
        inProcess: 'In Process',
        waiting:   'Waiting',
        reserved1: 'Reserved 1',
        reserved2: 'Reserved 2',
        reserved3: 'Reserved 3'
    };

    function showCarrierPopup(eqpName, statusKey) {
        const eqp = eqpData[eqpName];
        const items = (eqp && eqp[statusKey]) ? eqp[statusKey] : [];

        document.getElementById('cp-title').textContent = eqpName + '  ―  ' + (statusLabels[statusKey] || statusKey);

        const tbody = document.getElementById('cp-tbody');
        const empty = document.getElementById('cp-empty');
        const table = document.getElementById('cp-table');
        tbody.innerHTML = '';

        if (items.length === 0) {
            table.style.display = 'none';
            empty.style.display = 'block';
        } else {
            table.style.display = '';
            empty.style.display = 'none';
            for (const item of items) {
                const tr = document.createElement('tr');
                tr.innerHTML =
                    '<td>' + esc(item.carrier)     + '</td>' +
                    '<td>' + esc(item.lot)          + '</td>' +
                    '<td style="text-align:right;">' + (item.qty ?? 0) + '</td>' +
                    '<td>' + esc(item.pPID)         + '</td>' +
                    '<td>' + esc(item.nextFurnace)  + '</td>' +
                    '<td>' + esc(item.location)     + '</td>' +
                    '<td>' + esc(item.endTime)      + '</td>';
                tbody.appendChild(tr);
            }
        }

        document.getElementById('cp-overlay').style.display = 'block';
        const modal = document.getElementById('cp-modal');
        modal.style.display = 'flex';
    }

    function closeCarrierPopup() {
        document.getElementById('cp-overlay').style.display = 'none';
        document.getElementById('cp-modal').style.display = 'none';
    }

    function esc(v) {
        if (v == null) return '';
        return String(v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // Escapeキーで閉じる
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeCarrierPopup(); });

    // 自動更新

    const AUTO_REFRESH_INTERVAL = @ViewData["AutoRefreshIntervalSeconds"] * 1000;
    let autoRefreshTimer;

    async function refreshData() {
        try {
            const params = new URLSearchParams({ handler: 'Refresh' });
            const res = await fetch('@Url.Page("/Dashboard")?' + params.toString());
            if (!res.ok) return;
            const result = await res.json();
            if (result.success) { updateUI(result.data); logRefreshResult(result.data); }
        } catch (e) { console.error('自動更新エラー:', e); }
    }

    function countItems(items) { return (items && items.length > 0) ? items.length : 0; }

    function updateUI(equipmentsByType) {
        for (const [, equipments] of Object.entries(equipmentsByType)) {
            for (const eqp of equipments) {
                const n = eqp.eqpName;
                const set = (id, cnt) => { const el = document.getElementById(id); if (el) el.textContent = cnt > 0 ? cnt.toString() : ''; };
                set('cell-a-' + n, countItems(eqp.inProcess));
                set('cell-b-' + n, countItems(eqp.waiting));
                set('cell-c-' + n, countItems(eqp.reserved1));
                set('cell-d-' + n, countItems(eqp.reserved2));
                set('cell-e-' + n, countItems(eqp.reserved3));
                const ef = document.getElementById('cell-f-' + n);
                if (ef) ef.textContent = (eqp.inProcess && eqp.inProcess.length > 0) ? (eqp.inProcess[0].endTime || '') : '';
                const eg = document.getElementById('cell-g-' + n);
                if (eg) eg.textContent = eqp.schedule || '';
                // ポップアップ用データキャッシュを更新
                eqpData[n] = eqp;
            }
        }
    }

    function logRefreshResult(equipmentsByType) {
        const now = new Date().toLocaleTimeString();
        console.log('[Dashboard] データ更新 ' + now);
        for (const [, equipments] of Object.entries(equipmentsByType)) {
            for (const eqp of equipments) {
                console.log('  ' + eqp.eqpName + ' A:' + countItems(eqp.inProcess) + ' B:' + countItems(eqp.waiting));
            }
        }
    }

    function startAutoRefresh() {
        if (autoRefreshTimer) clearInterval(autoRefreshTimer);
        autoRefreshTimer = setInterval(refreshData, AUTO_REFRESH_INTERVAL);
        console.log('自動更新開始（' + (@ViewData["AutoRefreshIntervalSeconds"]) + '秒間隔）');
    }
</script>
}
